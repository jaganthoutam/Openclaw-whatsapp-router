# Extension Service — copy to .env and fill values

PORT=8090
NODE_ENV=development
LOG_LEVEL=info

# Must match ROUTER_SECRET in the router service
ROUTER_SECRET=router-secret

# Leave empty to use the built-in mock client.
# Set to your OpenClaw service URL (internal k8s DNS or localhost) to enable real routing.
# Examples:
#   http://openclaw-service:8080          (k8s ClusterIP)
#   http://localhost:3000                 (co-located in same pod)
OPENCLAW_BASE_URL=

# Bearer token / API key for the OpenClaw REST API (used by OpenClawRestAdapter)
OPENCLAW_API_KEY=
