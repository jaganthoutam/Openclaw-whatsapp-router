# Router Service — copy to .env and fill values

PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Secret used to authenticate the Admin API (X-Admin-Secret header)
ADMIN_SECRET=changeme

# Shared secret between router and extension services (X-Router-Secret header)
ROUTER_SECRET=router-secret

# Path to the JSON tenant registry file
TENANT_REGISTRY_PATH=./tenant-registry.json

# Directory where Baileys stores WhatsApp session credentials
WHATSAPP_SESSION_DIR=./whatsapp-session

# How long (ms) to remember a processed messageId to prevent duplicates (default 24h)
DEDUP_TTL_MS=86400000
