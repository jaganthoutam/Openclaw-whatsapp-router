# k8s Operator — copy to .env for local dev

OPERATOR_PORT=8080
LOG_LEVEL=INFO

# Secret the UI sends in X-Operator-Secret header
OPERATOR_SECRET=operator-secret

# Leave empty to use per-tenant namespaces (namespace == tenantId).
# Set to a namespace name to put all tenants in one namespace.
SHARED_NAMESPACE=

# How to find the ConfigMap and Deployment for a tenant:
CONFIGMAP_KEY=openclaw.json
CONFIGMAP_PREFIX=openclaw-config-
DEPLOYMENT_PREFIX=openclaw-

# Injected into openclaw.json as a reference field (not functional)
ROUTER_SERVICE_URL=http://openclaw-router.openclaw.svc.cluster.local:3000
